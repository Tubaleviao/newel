{
  "name": "rest-api-example",
  "version": "0.0.1",
  "private": true,
  "description": "Worked example: order management REST API using newel",
  "scripts": {
    "validate":    "newel validate    -s ./src/fabric.ts",
    "inspect":     "newel inspect     -s ./src/fabric.ts",
    "generate":    "newel generate    -c ./newel.config.ts",
    "diff":        "newel diff        -c ./newel.config.ts",
    "check-drift": "newel check-drift -c ./newel.config.ts"
  },
  "dependencies": {
    "@newel/core": "workspace:*",
    "@newel/generator-typescript": "workspace:*",
    "@newel/generator-openapi": "workspace:*",
    "@newel/generator-sql": "workspace:*",
    "@newel/generator-docs": "workspace:*",
    "@newel/generator-jsonschema": "workspace:*",
    "@newel/generator-rdf": "workspace:*",
    "@newel/generator-owl": "workspace:*"
  }
}
