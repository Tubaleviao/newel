{
  "name": "library-example",
  "version": "0.0.1",
  "private": true,
  "description": "Worked example: library management system using newel",
  "scripts": {
    "validate":    "newel validate    -s ./src/fabric.ts",
    "inspect":     "newel inspect     -s ./src/fabric.ts",
    "generate":    "newel generate    -c ./newel.config.ts",
    "diff":        "newel diff        -c ./newel.config.ts",
    "check-drift": "newel check-drift -c ./newel.config.ts",
    "setup":       "prisma generate --schema src/generated/app/schema.prisma && prisma db push --schema src/generated/app/schema.prisma",
    "dev:server":  "tsx watch src/generated/app/server.ts",
    "dev:client":  "cd src/generated/app/client && vite",
    "dev":         "concurrently -n server,client -c cyan,yellow \"pnpm dev:server\" \"pnpm dev:client\"",
    "start":       "tsx src/generated/app/server.ts"
  },
  "dependencies": {
    "@newel/core": "workspace:*",
    "@newel/generator-typescript": "workspace:*",
    "@newel/generator-openapi": "workspace:*",
    "@newel/generator-sql": "workspace:*",
    "@newel/generator-docs": "workspace:*",
    "@newel/generator-ui": "workspace:*",
    "@newel/generator-express": "workspace:*",
    "@newel/generator-prisma": "workspace:*",
    "@newel/generator-app": "workspace:*",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "vite": "^5.4.8"
  }
}
