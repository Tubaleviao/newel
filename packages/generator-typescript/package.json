{
  "name": "@newel/generator-typescript",
  "version": "0.0.1",
  "description": "TypeScript + Zod schema generator for newel",
  "keywords": ["newel", "codegen", "generator", "typescript", "zod", "schema"],
  "homepage": "https://github.com/Tubaleviao/newel#readme",
  "bugs": {
    "url": "https://github.com/Tubaleviao/newel/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tubaleviao/newel.git"
  },
  "license": "MIT",
  "author": "Tubaleviao",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/index.js", "dist/index.js.map", "dist/index.d.ts", "dist/index.d.ts.map"],
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=src",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@newel/core": "workspace:*",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
